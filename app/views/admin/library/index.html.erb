<% content_for :title, "Admin Library" %>

<main class="admin-page">
  <section class="admin-grid">
    <div class="admin-card">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Admin</span>
          <div class="page-title">Add Book PDF</div>
        </div>
      </div>

      <% if @book.errors.any? %>
        <div class="auth-errors">
          <% @book.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <%= form_with model: @book, url: create_book_admin_library_index_path, class: "admin-form" do |form| %>
        <div class="form-group">
          <%= form.label :title %>
          <%= form.text_field :title, class: "form-input", placeholder: "Class 6 Tamil Book" %>
        </div>

        <div class="form-group">
          <%= form.label :standard, "Class" %>
          <%= form.select :standard, Book::STANDARDS.map { |standard| [ "Std #{standard}", standard ] }, {}, class: "form-input" %>
        </div>

        <div class="form-group">
          <%= form.label :subject %>
          <%= form.select :subject, Book::SUBJECTS, {}, class: "form-input" %>
        </div>

        <lable for="pdf_file"  class="form-group">
          <%= form.label :pdf_file, "Click To Add File" %>

          <%= form.file_field :pdf_file, class: "", accept: "application/pdf",style:"display:none" %>
         
      
        </lable>

        <%= form.submit "Add book PDF", class: "button button-primary auth-submit" %>
      <% end %>
    </div>

    <div class="admin-card">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Admin</span>
          <div class="page-title">Add Question Paper PDF</div>
        </div>
        
      </div>

      <% if @question_paper.errors.any? %>
        <div class="auth-errors">
          <% @question_paper.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <%= form_with model: @question_paper, url: create_question_paper_admin_library_index_path, class: "admin-form" do |form| %>
        <div class="form-group">
          <%= form.label :title %>
          <%= form.text_field :title, class: "form-input", placeholder: "Class 6 Tamil Book Back Question Paper" %>
        </div>

        <div class="form-group">
          <%= form.label :category %>
          <%= form.text_field :category, class: "form-input", placeholder: "Tamil" %>
        </div>

        <div class="form-group">
          <%= form.label :year %>
          <%= form.number_field :year, class: "form-input", placeholder: "2026" %>
        </div>

        <div class="form-group">
          <label class="admin-checkbox">
            <%= form.check_box :is_premium %>
            <span>Premium paper</span>
          </label>
        </div>

        <div class="form-group">
          <%= form.label :pdf_file, "PDF file" %>
          <%= form.file_field :pdf_file, class: "form-input", accept: "application/pdf" %>
        </div>

        <%= form.submit "Add question paper PDF", class: "button button-primary auth-submit" %>
      <% end %>
    </div>

    <div class="admin-card">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Admin</span>
          <div class="page-title">Add Syllabus PDF</div>
        </div>
      </div>

      <% if @syllabus.errors.any? %>
        <div class="auth-errors">
          <% @syllabus.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <%= form_with model: @syllabus, url: create_syllabus_admin_library_index_path, class: "admin-form" do |form| %>
        <div class="form-group">
          <%= form.label :category %>
          <%= form.text_field :category, class: "form-input", placeholder: "Banking / NEET / JEE / UPSC" %>
        </div>

        <div class="form-group">
          <%= form.label :exam_name, "Exam name" %>
          <%= form.text_field :exam_name, class: "form-input", placeholder: "IBPS PO / Clerk" %>
        </div>

        <div class="form-group">
          <%= form.label :title %>
          <%= form.text_field :title, class: "form-input", placeholder: "IBPS PO Full Syllabus PDF" %>
        </div>

        <div class="form-group">
          <%= form.label :description %>
          <%= form.text_area :description, class: "form-input", rows: 4, placeholder: "Short description for this syllabus PDF" %>
        </div>

        <div class="form-group">
          <%= form.label :pdf_file, "PDF file" %>
          
          <%= form.file_field :pdf_file, class: "form-input", accept: "application/pdf" %>
        </div>

        <%= form.submit "Add syllabus PDF", class: "button button-primary auth-submit" %>
      <% end %>
    </div>
  </section>

  <section class="admin-list-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Books</span>
        <div class="section-title">Current book entries</div>
      </div>
    </div>

    <div class="books-table-shell">
      <table class="books-table">
        <thead>
          <tr>
            <th>Class</th>
            <th>Subject</th>
            <th>Title</th>
            <th>PDF</th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td>Std <%= book.standard %></td>
              <td><%= book.subject %></td>
              <td><%= book.title %></td>
              <td>
                <% if (book_href = pdf_href_for(book)) %>
                  <%= link_to "Open PDF", book_href, class: "table-pdf-link", target: external_href?(book_href) ? "_blank" : nil, rel: external_href?(book_href) ? "noopener" : nil %>
                <% else %>
                  -
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="admin-list-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Question Papers</span>
        <div class="section-title">Current question paper entries</div>
      </div>
    </div>

    <div class="books-table-shell">
      <table class="books-table">
        <thead>
          <tr>
            <th>Category</th>
            <th>Year</th>
            <th>Title</th>
            <th>PDF</th>
          </tr>
        </thead>
        <tbody>
          <% @question_papers.each do |paper| %>
            <tr>
              <td><%= paper.category %></td>
              <td><%= paper.year %></td>
              <td><%= paper.title %></td>
              <td>
                <% if (paper_href = pdf_href_for(paper)) %>
                  <%= link_to "Open PDF", paper_href, class: "table-pdf-link", target: external_href?(paper_href) ? "_blank" : nil, rel: external_href?(paper_href) ? "noopener" : nil %>
                <% else %>
                  -
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="admin-list-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Syllabuses</span>
        <div class="section-title">Current syllabus entries</div>
      </div>
    </div>

    <div class="books-table-shell">
      <table class="books-table">
        <thead>
          <tr>
            <th>Category</th>
            <th>Exam</th>
            <th>Title</th>
            <th>Description</th>
            <th>PDF</th>
          </tr>
        </thead>
        <tbody>
          <% @syllabuses.each do |syllabus| %>
            <tr>
              <td><%= syllabus.category %></td>
              <td><%= syllabus.exam_name %></td>
              <td><%= syllabus.title %></td>
              <td><%= syllabus.description.presence || "-" %></td>
              <td>
                <% if (syllabus_href = pdf_href_for(syllabus)) %>
                  <%= link_to "Open PDF", syllabus_href, class: "table-pdf-link ", target: "_blank", rel: "noopener" %>
                <% else %>
                  -
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</main>
