<% content_for :title, "Syllabus" %>

<main class="syllabus-page">
  <section class="syllabus-hero">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Syllabus</span>
        <div class="page-title">Exam syllabus by category</div>
      </div>
      <div class="section-note text-note">Browse the major topics for banking, medical, engineering, and government exams in one place.</div>
    </div>

    <div class="syllabus-highlight-grid">
      <article class="syllabus-highlight-card">
        <span class="syllabus-highlight-label">Quick lookup</span>
        <strong><%= @syllabus_groups.values.flatten.size %> syllabus PDFs</strong>
        <p class="text-note">Open syllabus PDFs by exam category from the admin-managed syllabus library.</p>
      </article>
      <article class="syllabus-highlight-card">
        <span class="syllabus-highlight-label">Coverage</span>
        <strong><%= @categories.presence&.join(", ") || "No categories yet" %></strong>
        <p class="text-note">Each row links directly to a syllabus PDF added by the admin.</p>
      </article>
    </div>

    <div class="syllabus-filter-bar" aria-label="Syllabus filters">
      <% @filters.each do |filter| %>
        <%= link_to filter[:label], syllabuses_path(filter: filter[:value]), class: "syllabus-filter-chip #{'syllabus-filter-chip-active' if @selected_filter == filter[:value]}" %>
      <% end %>
    </div>
  </section>

  <section class="syllabus-group-list">
    <% @syllabus_groups.each do |category, syllabuses| %>
      <article class="syllabus-group-card">
        <div class="section-heading">
          <div>
            <span class="eyebrow"><%= category %></span>
            <div class="section-title"><%= category %></div>
          </div>
          <div class="section-note text-note">Syllabus PDFs available for <%= category %> exams.</div>
        </div>

        <div class="syllabus-table-shell">
          <table class="syllabus-table">
            <thead>
              <tr>
                <th>Exam</th>
                <th>Title</th>
                <th>Description</th>
                <th>PDF</th>
              </tr>
            </thead>
            <tbody>
              <% syllabuses.each do |syllabus| %>
                <tr>
                  <td class="syllabus-exam-name-cell"><%= syllabus.exam_name %></td>
                  <td><%= syllabus.title %></td>
                  <td><%= syllabus.description.presence || "-" %></td>
                  <td>
                    <% if syllabus.pdf_file.attached? %>
                      <%= link_to "Open PDF", url_for(syllabus.pdf_file), class: "table-pdf-link", target: "_blank", rel: "noopener" %>
                    <% else %>
                      -
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </article>
    <% end %>

    <% if @syllabus_groups.empty? %>
      <article class="syllabus-group-card">
        <div class="section-title">No syllabus PDFs found</div>
        <p class="text-note">Add syllabus entries from the admin library page to show them here.</p>
      </article>
    <% end %>
  </section>
</main>
