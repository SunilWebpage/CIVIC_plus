<div class="auth-gate">
  <div class="auth-gate-backdrop"></div>

  <section class="auth-gate-modal" aria-labelledby="auth-gate-title">
    <span class="eyebrow">Login Required</span>
    <div id="auth-gate-title" class="text-title-md">Sign in before entering the study app</div>
    <p class="auth-text text-body">
      The home page is ready in the background. Log in or create an account to continue.
    </p>

    <% if flash[:alert] %>
      <div class="auth-errors">
        <p><%= flash[:alert] %></p>
      </div>
    <% end %>

    <%= form_with url: login_path, class: "auth-form auth-gate-form" do |form| %>
      <div class="form-group">
        <%= form.label :email %>
        <%= form.email_field :email, class: "form-input", placeholder: "name@example.com" %>
      </div>

      <div class="form-group">
        <%= form.label :password %>
        <%= form.password_field :password, class: "form-input", placeholder: "Enter your password" %>
      </div>

      <div class="auth-gate-actions">
        <%= form.submit "Login", class: "button button-primary auth-submit" %>
        <%= link_to "Create account", signup_path, class: "button button-secondary" %>
      </div>
    <% end %>

    <div class="auth-gate-actions">
      <%= link_to "Open full login page", login_path, class: "auth-link" %>
    </div>
  </section>
</div>
