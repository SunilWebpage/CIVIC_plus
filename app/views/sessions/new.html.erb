<% content_for :title, "Login" %>

<main class="auth-page">
  <section class="auth-card auth-card-compact">
    <div class="auth-copy">
      <span class="eyebrow">Login</span>
      <div class="text-display-lg">Welcome back</div>
      <p class="auth-text text-body-lg">Log in to continue your study practice.</p>
    </div>

    <% if flash.now[:alert] %>
      <div class="auth-errors">
        <p><%= flash.now[:alert] %></p>
      </div>
    <% end %>

    <%= form_with url: login_path, class: "auth-form" do |form| %>
      <div class="form-group">
        <%= form.label :email %>
        <%= form.email_field :email, class: "form-input", placeholder: "name@example.com" %>
      </div>

      <div class="form-group">
        <%= form.label :password %>
        <%= form.password_field :password, class: "form-input", placeholder: "Enter your password" %>
      </div>

      <div class="auth-actions">
        <%= form.submit "Login", class: "button button-primary auth-submit" %>
        <%= link_to "Create a new account", signup_path, class: "auth-link" %>
      </div>
    <% end %>
  </section>
</main>
