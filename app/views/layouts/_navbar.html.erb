<header class="site-header">
  <nav class="site-navbar" aria-label="Main navigation">
    <%= link_to root_path, class: "site-brand" do %>
      <%= image_tag "App_logo.png", alt: "CIVIC+ logo", class: "site-brand-logo" %>
      <span class="site-brand-copy">
        <strong>CIVIC+</strong>
        <small>Your Path to Govt Exams</small>
      </span>
    <% end %>

    <div class="site-nav-links">
      <%= link_to "Home", question_papers_path, class: "site-nav-link #{'site-nav-link-active' if current_page?(question_papers_path)}" %>
      <%= link_to "Library", books_path, class: "site-nav-link #{'site-nav-link-active' if current_page?(books_path)}" %>
      <%= link_to "Syllabus", syllabuses_path, class: "site-nav-link #{'site-nav-link-active' if current_page?(syllabuses_path)}" %>
      <%= link_to "Practice", exam_practices_path, class: "site-nav-link #{'site-nav-link-active' if controller_name == 'exam_practices' || controller_name == 'answer_sheets'}" %>
      <%= link_to "Bot", bots_path, class: "site-nav-link #{'site-nav-link-active' if current_page?(bots_path)}" %>
      <%= link_to "Categories", "#{root_path}#paper-library", class: "site-nav-link" %>
      <% if admin? %>
        <%= link_to "Admin", admin_library_index_path, class: "site-nav-link #{'site-nav-link-active' if controller_path == 'admin/library'}" %>
      <% end %>
      <%= link_to "Chat", chats_path, class: "site-nav-link #{'site-nav-link-active' if current_page?(chats_path)}" %>
    </div>

    <div class="site-nav-actions">
      <% if logged_in? %>
        <div class="site-user-block">
          <span class="site-user-pill"><%= current_user.email %></span>
        </div>
        <div class="site-logout-block">
          <%= button_to "Logout", logout_path, method: :delete, class: "site-nav-button site-nav-button-secondary", form: { class: "site-logout-form" } %>
        </div>
      <% else %>
        <%= link_to "Login", login_path, class: "site-nav-link" %>
        <%= link_to "Sign Up", signup_path, class: "site-nav-button" %>
      <% end %>
    </div>
  </nav>
</header>
